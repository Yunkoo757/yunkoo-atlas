{
  "name": "yunkoo-atlas",
  "private": true,
  "version": "1.2.27",
  "description": "Trader Atlas — trading journal with IndexedDB and Electron desktop support",
  "author": "Trader Atlas",
  "type": "module",
  "main": "dist-electron/main.js",
  "scripts": {
    "typecheck": "tsc -b --pretty false && tsc -p tsconfig.electron.json --pretty false",
    "test": "pnpm test:icons && node scripts/run-quality-node-tests.mjs && node scripts/run-regression-tests.mjs && node scripts/check-governance.mjs --require-execution",
    "check:governance": "node scripts/check-governance.mjs",
    "test:icons": "node --test scripts/linear-icons/core.test.mjs",
    "test:release": "node --test scripts/release-command.test.mjs scripts/release-artifacts.test.mjs",
    "test:runner-contract": "node --test scripts/test-discovery.test.mjs",
    "test:analytics-baseline": "node --test scripts/fixtures/*.test.mjs",
    "test:asset-lifecycle:electron": "node scripts/run-asset-lifecycle-platform.mjs",
    "test:electron-safety:platform": "node scripts/run-electron-safety-platform.mjs",
    "test:forced-kill:electron": "node scripts/run-forced-kill-evidence.mjs",
    "icons:generate": "node scripts/linear-icons/generate.mjs",
    "icons:app": "node scripts/generate-app-icon.mjs",
    "qa:icons": "node scripts/qa-linear-icons.mjs",
    "dev": "vite",
    "dev:electron": "cross-env ELECTRON=1 vite",
    "build": "pnpm typecheck && vite build && node scripts/check-bundle-budget.mjs",
    "build:app": "pnpm typecheck && cross-env ELECTRON=1 vite build && node scripts/check-bundle-budget.mjs && node scripts/copy-sql-wasm.mjs",
    "check:bundle": "node scripts/check-bundle-budget.mjs",
    "preview": "vite preview",
    "dist": "pnpm build:app && electron-builder",
    "dist:mac": "pnpm build:app && electron-builder --mac",
    "dist:win": "pnpm build:app && electron-builder --win",
    "dist:win:purge-commit": "cross-env ATLAS_ENABLE_ASSET_PURGE_COMMIT=true VITE_ENABLE_ASSET_PURGE_COMMIT=true pnpm dist:win",
    "dist:mac:purge-commit": "cross-env ATLAS_ENABLE_ASSET_PURGE_COMMIT=true VITE_ENABLE_ASSET_PURGE_COMMIT=true pnpm dist:mac",
    "release:patch": "node scripts/release.mjs patch",
    "release:minor": "node scripts/release.mjs minor",
    "release:major": "node scripts/release.mjs major",
    "qa": "node scripts/qa-phase1.mjs && node scripts/qa-phase1-image.mjs && node scripts/qa-workbench.mjs",
    "qa:core": "node scripts/qa-phase1.mjs",
    "qa:image": "node scripts/qa-phase1-image.mjs",
    "qa:workbench": "node scripts/qa-workbench.mjs",
    "qa:design": "node scripts/qa-design-contract.mjs",
    "qa:sidebar": "node scripts/qa-sidebar-navigation.mjs",
    "qa:linear": "node scripts/qa-linear-rebuild.mjs",
    "benchmark:analytics": "pnpm build && node scripts/benchmark-analytics.mjs",
    "benchmark:persistence": "node scripts/benchmark-persistence.mjs",
    "benchmark:persistence:release": "node scripts/run-persistence-release-gate.mjs",
    "benchmark:persistence:raw-release": "node scripts/benchmark-persistence.mjs --release",
    "benchmark:web-zip": "node scripts/benchmark-web-zip.mjs",
    "benchmark:web-zip:release": "node scripts/benchmark-web-zip.mjs --release",
    "spike:generation": "node scripts/spikes/electron-generation/run-generation-spike.mjs",
    "verify:release-trains": "node scripts/verify-release-train-evidence.mjs --require-complete",
    "verify:release-train-drills": "node scripts/run-release-train-drills.mjs --require-complete",
    "verify:generation-decision": "node scripts/verify-generation-decision.mjs --require-complete",
    "measure:json-compatibility": "node --experimental-strip-types scripts/measure-json-import-compatibility.mjs",
    "qa:dashboard-10k": "pnpm build && node scripts/qa-dashboard-10k.mjs",
    "qa:electron": "node scripts/qa-electron.mjs",
    "qa:ci": "node scripts/qa-ci.mjs",
    "qa:release": "node scripts/qa-release.mjs",
    "qa:full": "node scripts/qa-release.mjs --full"
  },
  "dependencies": {
    "@fontsource-variable/inter": "5.2.8",
    "@fontsource/geist-sans": "^5.2.5",
    "@fontsource/jetbrains-mono": "^5.2.8",
    "@tanstack/react-virtual": "^3.14.5",
    "@tiptap/core": "^2.8.0",
    "@tiptap/extension-bubble-menu": "^2.8.0",
    "@tiptap/extension-image": "^2.8.0",
    "@tiptap/extension-placeholder": "^2.8.0",
    "@tiptap/extension-task-item": "^2.8.0",
    "@tiptap/extension-task-list": "^2.8.0",
    "@tiptap/pm": "^2.8.0",
    "@tiptap/react": "^2.8.0",
    "@tiptap/starter-kit": "^2.8.0",
    "archiver": "^8.0.0",
    "clsx": "^2.1.1",
    "electron-updater": "^6.8.9",
    "jszip": "^3.10.1",
    "lucide-react": "^0.451.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.26.2",
    "recharts": "^2.12.7",
    "sharp": "^0.35.1",
    "sql.js": "^1.14.1",
    "yauzl": "^2.10.0",
    "zustand": "^4.5.5"
  },
  "devDependencies": {
    "@types/archiver": "^8.0.0",
    "@types/jszip": "^3.4.1",
    "@types/node": "^22.20.1",
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.0",
    "@types/sql.js": "^1.4.11",
    "@types/yauzl": "^2.10.3",
    "@vitejs/plugin-react": "^6.0.3",
    "chrome-remote-interface": "^0.34.0",
    "cross-env": "^10.1.0",
    "electron": "^43.1.0",
    "electron-builder": "^26.15.3",
    "playwright": "^1.60.0",
    "puppeteer-core": "^25.1.0",
    "typescript": "^5.6.2",
    "vite": "^8.1.4",
    "vite-plugin-electron": "^1.1.0",
    "vite-plugin-electron-renderer": "^1.0.0"
  },
  "build": {
    "appId": "com.yunkoo-atlas.app",
    "productName": "Trader Atlas",
    "electronDist": "node_modules/electron/dist",
    "icon": "build/icon.ico",
    "directories": {
      "output": "release"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "Yunkoo757",
        "repo": "yunkoo-atlas",
        "private": true
      }
    ],
    "files": [
      "dist/**/*",
      "dist-electron/**/*"
    ],
    "extraResources": [
      {
        "from": "node_modules/sql.js/dist/sql-wasm.wasm",
        "to": "sql-wasm.wasm"
      }
    ],
    "mac": {
      "icon": "build/icon.png",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64",
            "x64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "arm64",
            "x64"
          ]
        }
      ],
      "category": "public.app-category.finance",
      "artifactName": "Trader-Atlas-${version}-mac-${arch}.${ext}"
    },
    "win": {
      "icon": "build/icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "Trader-Atlas-${version}-win-${arch}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "include": "build/installer.nsh",
      "language": "2052",
      "installerLanguages": [
        "zh_CN"
      ],
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico",
      "installerHeader": "build/installerHeader.bmp",
      "installerSidebar": "build/installerSidebar.bmp",
      "uninstallerSidebar": "build/installerSidebar.bmp"
    }
  },
  "pnpm": {
    "overrides": {
      "undici@>=7.0.0 <7.28.0": "7.28.0"
    }
  }
}
